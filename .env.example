# ─── REQUIRED ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Must be at least 32 characters. Server will refuse to start in production without it.
JWT_SECRET=

# SMTP credentials for transactional email (verification links, welcome emails, etc.)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# ─── STRONGLY RECOMMENDED ─────────────────────────────────────────────────────
NODE_ENV=development         # development | staging | production

# Public URL of this server (used in verification email links)
APP_URL=http://localhost:3000

# Public URL of the frontend (used in CORS and email links)
FRONTEND_URL=http://localhost:8001

# Sender address for outbound email
EMAIL_FROM=noreply@100k-pathway.com

# ─── DATABASE (Supabase) ───────────────────────────────────────────────────────
# Required if using Supabase instead of file-based LocalApiStore
SUPABASE_URL=
SUPABASE_KEY=

# ─── PAYMENTS ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
# Set to "true" to simulate payments locally without Stripe
PAYMENTS_SIMULATION=false

# ─── JWT TUNING ───────────────────────────────────────────────────────────────
# How long issued tokens stay valid (jsonwebtoken format: 7d, 24h, 30m, etc.)
JWT_EXPIRY=7d

# ─── OPTIONAL ─────────────────────────────────────────────────────────────────
LOG_LEVEL=debug              # debug | info | warn | error
APP_VERSION=1.0.0

# ─── REMOVED (Phase 1 security fix) ──────────────────────────────────────────
# ADMIN_EMAIL was used to grant admin role at signup time by email match.
# This was removed because: (1) if unset the guard silently fails, (2) anyone
# knowing the admin email could register it and gain admin access if not caught.
# Admin role must now be set directly in data/users.json after account creation.
# ADMIN_EMAIL=
